# Test Site configuration — baked into the client bundle at build time.
# NEXT_PUBLIC_IS_TEST_SITE enables the "TEST SITE ONLY" banner and the
# click-interceptor that blocks all enrollment/mutation actions in the UI.
# IS_TEST_SITE is read by the Edge Middleware at runtime to block non-GET/HEAD
# API requests, preventing any real mutations on this demo/sample deployment.
NEXT_PUBLIC_IS_TEST_SITE=true
IS_TEST_SITE=true
